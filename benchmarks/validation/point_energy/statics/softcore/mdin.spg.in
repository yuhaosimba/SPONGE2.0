point energy validation for softcore

mode = nvt
velocity_max = 20
constrain_mode = SHAKE
dt = 0
thermostat = middle_langevin
target_temperature = 300
middle_langevin_gamma = 10
barostat = andersen_barostat
target_pressure = 1
cutoff = 8
neighbor_list_skin_permit = 0.75
PM_update_interval = 1
PM_print_detail = 1

default_in_file_prefix = ./softcore
step_limit = 1
write_information_interval = 1

lambda_lj = 0.2
